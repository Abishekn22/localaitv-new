# ─────────────────────────────────────────────────────────────────────────────
# LocalAI TV — environment config
#
# Copy this file to `.env` and adjust as needed:   cp .env.example .env
# `.env` is gitignored; this `.env.example` is the committed template.
# Vite only exposes vars prefixed with VITE_ to the app. Restart the dev
# server / rebuild after changing any value.
# ─────────────────────────────────────────────────────────────────────────────

# Which backend URL set to use: dev | prod
#   dev  → http://localhost:5000/api  (both backends)
#   prod → https://localaitv.com/api  (main) + https://aiservices.localaitv.com/api (aiservices)
# This flag wins over Vite's npm command. Leave it unset to instead follow the
# command automatically (npm run dev → dev, npm run build → prod).
VITE_ENV=dev

# ── Optional explicit URL overrides ──────────────────────────────────────────
# If set, these take priority over VITE_ENV and point a backend at any URL.
# Useful for staging, a teammate's tunnel, or a non-default local port.
# Leave them commented out to use the VITE_ENV defaults above.

# Main app backend (news, incidents, auth, election, users, …)
# VITE_API_BASE=https://localaitv.com/api

# aimodelsss backend (classifieds feed + forms + upload)
# VITE_API_BASE_2=https://aiservices.localaitv.com/api
